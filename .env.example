# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yalla.house

# Twilio (Voice + SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_DE=+49xxxxxxxxxx   # DE phone number from Twilio console

# 360dialog (WhatsApp)
WHATSAPP_API_KEY=your-360dialog-api-key
WHATSAPP_PHONE_ID=your-phone-number-id

# Immoscout24
IMMOSCOUT24_CLIENT_ID=your-client-id
IMMOSCOUT24_CLIENT_SECRET=your-client-secret
IMMOSCOUT24_SANDBOX=true

# Immowelt
IMMOWELT_API_KEY=your-api-key
IMMOWELT_SANDBOX=true

# Inngest
INNGEST_SIGNING_KEY=signkey-...
INNGEST_EVENT_KEY=...

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://yalla.house
DEFAULT_LOCALE=de
